# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values for your environment

# =============================================================================
# CORE SETTINGS
# =============================================================================
ENV=prod                        # Set to "prod" for production mode
DEBUG=False                     # Disable debug in production
HOST=0.0.0.0
PORT=8000

# =============================================================================
# DATABASE - PostgreSQL (REQUIRED for production)
# =============================================================================
# Use a PostgreSQL database URL from your hosting provider
# Railway: Get from railway dashboard or $DATABASE_URL
# Render: Get from Render dashboard or $DATABASE_URL
# Neon/Custom: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_resume_optimizer

# Connection pool settings
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# SECURITY
# =============================================================================
# IMPORTANT: Generate a strong secret key (at least 32 characters)
# Use: openssl rand -base64 32
JWT_SECRET_KEY=your-super-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# =============================================================================
# CORS - Configure for your frontend URL
# =============================================================================
# Comma-separated list of allowed origins
# Production: https://your-frontend.vercel.app
# Development: http://localhost:3000,http://localhost:3001
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_MAX=100             # Requests per minute per IP

# =============================================================================
# OPTIONAL: AI PROVIDERS (leave empty for local rule-based analyzer)
# =============================================================================
# CLAUDE_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AI_TIMEOUT_SECONDS=20
# AI_MAX_RETRIES=3

# =============================================================================
# OPTIONAL: EMAIL (for future features)
# =============================================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# EMAIL_FROM=noreply@example.com

# =============================================================================
# OPTIONAL: ERROR TRACKING
# =============================================================================
# SENTRY_DSN=https://...@sentry.io/...